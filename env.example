# Конфигурация для RAG-ассистента
# Скопируйте этот файл в .env и заполните значения

# ============================================
# API НАСТРОЙКИ
# ============================================
# Использовать ProxyAPI (true/false, по умолчанию false)
USE_PROXYAPI=true

# Ключ API (ProxyAPI или OpenAI)
PROXYAPI_KEY=your_proxyapi_key_here

# Базовый URL API (для ProxyAPI)
PROXYAPI_BASE_URL=https://api.proxyapi.ru/openai/v1

# Ключ OpenAI (если USE_PROXYAPI=false)
# OPENAI_API_KEY=your_openai_key_here

# ============================================
# НАСТРОЙКИ МОДЕЛЕЙ
# ============================================
# Модель для генерации ответов (gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo и др.)
MODEL_NAME=gpt-4o-mini

# Модель для создания эмбеддингов (text-embedding-3-small, text-embedding-3-large)
EMBEDDING_MODEL=text-embedding-3-small

# Температура генерации (0.0-2.0, по умолчанию 0.7)
# TEMPERATURE=0.7

# ============================================
# TELEGRAM БОТ
# ============================================
# Токен Telegram бота (опционально, для режима Telegram бота)
# Получите токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ID администратора в Telegram для отправки сложных вопросов
# Получите ID через @userinfobot в Telegram
TELEGRAM_ADMIN_ID=your_telegram_admin_id_here

# URL репозитория GitHub для синхронизации
GITHUB_REPO_URL=https://github.com/Cka3o4Huk-04/RAG-NeoMoney

# ============================================
# АВТОМАТИЧЕСКАЯ СИНХРОНИЗАЦИЯ (опционально)
# ============================================
# Включить автоматическую синхронизацию (true/false, по умолчанию: false)
AUTO_SYNC_ENABLED=true

# Время автоматической синхронизации (формат ЧЧ:ММ, по умолчанию: 03:00)
AUTO_SYNC_TIME=03:00

# ============================================
# НАСТРОЙКИ КАЧЕСТВА RAG (опционально)
# ============================================
# Количество документов для поиска (по умолчанию: 3)
# RAG_TOP_K=3

# Минимальный порог релевантности (0.0-1.0, по умолчанию: 0.5)
# MIN_RELEVANCE_SCORE=0.5

# Размер чанка при разбиении документов (по умолчанию: 500)
# CHUNK_SIZE=500

# Перекрытие между чанками (по умолчанию: 50)
# CHUNK_OVERLAP=50

# ============================================
# НАСТРОЙКИ ХРАНИЛИЩА (опционально)
# ============================================
# Директория для сохранения данных ChromaDB
# CHROMA_PERSIST_DIR=./chroma_db

# Файл кеша ответов
# CACHE_FILE=cache.json

# Файл базы данных логов
# LOGS_DB_FILE=logs.db