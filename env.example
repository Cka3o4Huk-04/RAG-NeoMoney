# Конфигурация для RAG-ассистента
# Скопируйте этот файл в .env и заполните значения

# ============================================
# API НАСТРОЙКИ
# ============================================
# Ключ API (ProxyAPI или OpenAI)
API_KEY=your_api_key_here

# Базовый URL API (ProxyAPI, OpenAI или любой совместимый)
API_URL=https://api.proxyapi.ru/openai/v1

# ============================================
# TELEGRAM БОТ
# ============================================
# Токен Telegram бота (опционально, для режима Telegram бота)
# Получите токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ============================================
# НАСТРОЙКИ МОДЕЛЕЙ
# ============================================
# Модель для генерации ответов (gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo и др.)
API_MODEL=gpt-4o-mini

# Модель для создания эмбеддингов (text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002)
API_EMBEDDING=text-embedding-3-small

# Температура генерации (0.0-2.0, по умолчанию 0.7)
# TEMPERATURE=0.7

# ============================================
# НАСТРОЙКИ ПРОМПТОВ И ДОКУМЕНТОВ
# ============================================
# Папка с системными промптами (по умолчанию: prompts)
# PROMPTS_DIR=prompts

# Папка с документами базы знаний (по умолчанию: knowledge_base)
# KNOWLEDGE_BASE_DIR=knowledge_base

# ============================================
# НАСТРОЙКИ ХРАНИЛИЩА
# ============================================
# Директория для сохранения данных ChromaDB
# CHROMA_PERSIST_DIR=./chroma_db

# Файл кеша ответов
# CACHE_FILE=cache.json

# Файл базы данных логов
# LOGS_DB_FILE=logs.db

# ============================================
# АЛЬТЕРНАТИВНЫЕ НАСТРОЙКИ (опционально)
# ============================================
# Использовать ProxyAPI (true/false, по умолчанию false)
# USE_PROXYAPI=false

# Ключ ProxyAPI (если USE_PROXYAPI=true)
# PROXYAPI_KEY=your_proxyapi_key_here

# URL ProxyAPI (если USE_PROXYAPI=true)
# PROXYAPI_BASE_URL=https://api.proxyapi.ru/openai/v1

# Ключ OpenAI (если USE_PROXYAPI=false)
# OPENAI_API_KEY=your_openai_key_here